{
  "manifest_version": 3,
  "name": "ChatGPT Zed Bridge",
  "version": "0.1.1",
  "description": "Collapse ChatGPT code blocks and open them in Zed.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "host_permissions": [
    "https://chatgpt.com/*",
    "http://127.0.0.1:8765/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
